  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.1",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.7",
    "workbox-window": "^7.4.1",
